# LOCAL RUN ONLY. Copy to `.env` (gitignored, never pushed) to run the Space on
# your machine. For the HOSTED Hugging Face Space, do NOT use this file — set the
# same values as Space Secrets (Settings -> Variables and secrets), because a
# .env is not uploaded and the Space is public.
GEMINI_USE_VERTEX=true
GCP_PROJECT=l
GCP_LOCATION=global
GEMINI_MODEL=gemini-2.5-pro

# Pick ONE of these for the credentials:
# (a) point to the service-account key file (relative to this folder):
GOOGLE_APPLICATION_CREDENTIALS=../../vertex-key.json
# (b) OR base64 of the key JSON (one clean line — best for secret fields):
# GOOGLE_APPLICATION_CREDENTIALS_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...
# (c) OR the raw key JSON:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account", ...}
