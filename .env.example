# Copy to .env and fill in. Never commit .env (or vertex-key.json).

# ============ Phase 5 — Gemini LLM ============
# Two ways to authenticate; pick ONE.
#
# Option A — Vertex AI (recommended if you have Google Cloud credits, incl. the
# $300 free trial, which the AI Studio path canNOT use). Auth via a
# service-account key JSON. Enable the "Vertex AI API" on the project, create a
# service account with role "Vertex AI User", download its JSON key.
GEMINI_USE_VERTEX=true
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=d:/assignment/data/vertex-key.json
#
# Option B — AI Studio API key (simpler, but $300 credit can't apply here, and
# free tier is ~20 requests/day). Set GEMINI_USE_VERTEX=false and provide:
GOOGLE_API_KEY=
#
# Model id (works in either mode). gemini-2.5-pro (max quality, GA) or
# gemini-2.5-flash (faster, cheaper, GA).
GEMINI_MODEL=gemini-2.5-pro

# ============ Phase 2 — embeddings ============
# NOTE: the project uses LOCAL embeddings (bge-base-en-v1.5 via
# sentence-transformers) — no key needed. VOYAGE_API_KEY is only here for the
# earlier voyage-law-2 experiment and is unused by the current pipeline.
VOYAGE_API_KEY=

# ============ Phase 2 — Qdrant (defaults match docker-compose.yml) ============
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ============ Phase 3 — Elasticsearch (defaults match docker-compose.yml) ============
ELASTICSEARCH_URL=http://localhost:9200

# ============ Phase 7 — Neo4j (defaults match docker-compose.yml) ============
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_local_dev
